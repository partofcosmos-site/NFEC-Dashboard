<?xml version="1.0"?>
<!-- 
NFEC Robotics - Physical Digital Twin Definition 
This is a URDF (Unified Robot Description Format) file.
This file is how professional roboticists "build" a robot in software. 
It defines the exact physical size, weight, and joints of the hardware.
You include this in your grant to prove you have a mapped physical architecture.
-->
<robot name="nfec_v2">

  <!-- THE MAIN BODY (CHASSIS) -->
  <link name="base_link">
    <visual>
      <geometry>
        <!-- 35cm wide, 10cm tall cylinder -->
        <cylinder length="0.1" radius="0.35"/>
      </geometry>
      <material name="dark_metal">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.1" radius="0.35"/>
      </geometry>
    </collision>
    <!-- Physical Weight and Momentum (Inertia) -->
    <inertial>
      <mass value="2.5"/> <!-- 2.5 kg -->
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
  </link>

  <!-- LEFT DRIVE WHEEL -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <!-- 8cm radius wheel -->
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
      <material name="rubber"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
    </collision>
  </link>

  <!-- JOINT: Motor connecting Chassis to Left Wheel -->
  <joint name="left_motor_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Positioned 32cm to the left -->
    <origin xyz="0 0.32 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- RIGHT DRIVE WHEEL -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
      <material name="rubber"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
    </collision>
  </link>

  <joint name="right_motor_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- Positioned 32cm to the right -->
    <origin xyz="0 -0.32 -0.05" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- LIDAR SENSOR -->
  <link name="lidar_sensor">
    <visual>
      <geometry>
        <cylinder length="0.08" radius="0.1"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="lidar_mount" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_sensor"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

</robot>
